{
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "Bash(npx vite *)",
      "Bash(git add *)",
      "Bash(git rm *)",
      "Bash(git commit -m ' *)",
      "PowerShell(npx tsc -b --pretty false 2>&1)",
      "PowerShell(if \\($?\\) { \"TYPECHECK OK\" })",
      "PowerShell(npx tsc --noEmit -p tsconfig.json 2>&1)",
      "PowerShell(git add -A)"
    ]
  }
}
